{
  "manifest_version": 3,
  "name": "SkillsPath",
  "version": "1.0",
  "description": "Bridges Canvas and IBM SkillsBuild data to your SkillsPath advisor.",

  "permissions": ["storage"],

  "host_permissions": [
    "*://*.instructure.com/*",
    "*://*.canvaslms.com/*",
    "*://*.edu/*",
    "*://skills.yourlearning.ibm.com/*",
    "*://*.yourlearning.ibm.com/*",
    "http://localhost/*",
    "https://skillspath.github.io/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.instructure.com/*",
        "*://*.canvaslms.com/*",
        "*://*.edu/*"
      ],
      "js": ["content-canvas.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://skills.yourlearning.ibm.com/*",
        "*://*.yourlearning.ibm.com/*"
      ],
      "js": ["content-skillsbuild.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "https://skillspath.github.io/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/logo16.png",
    "48":  "icons/logo48.png",
    "128": "icons/logo128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "SkillsPath",
    "default_icon": {
      "16":  "icons/logo16.png",
      "48":  "icons/logo48.png",
      "128": "icons/logo128.png"
    }
  }
}
